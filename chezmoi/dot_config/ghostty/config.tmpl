# Start a normal login shell. Keep formula rendering opt-in.
command = /bin/zsh -l

# Typography. Menlo currently gives the clearest @ glyph on this setup.
font-family = Menlo
font-size = 14
font-thicken = true
adjust-cell-height = 2

# Theme and window appearance.
theme = Catppuccin Mocha
background-opacity = 0.85
background-blur = 30
background-image = {{ .chezmoi.homeDir }}/.config/ghostty/backgrounds/night-mountains.jpg
background-image-opacity = 0.18
background-image-position = center
background-image-fit = cover
background-image-repeat = false
macos-titlebar-style = transparent
window-padding-x = 10
window-padding-y = 8
window-save-state = never
window-theme = auto

# Cursor and mouse.
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8
mouse-hide-while-typing = true
copy-on-select = clipboard

# Quick terminal.
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# Paste safety and shell integration.
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
shell-integration = detect

# Tabs, splits, font size, reload, and quick terminal.
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+w=close_surface
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size
keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = cmd+shift+e=equalize_splits
keybind = cmd+shift+f=toggle_split_zoom
keybind = cmd+shift+comma=reload_config

scrollback-limit = 25000000
