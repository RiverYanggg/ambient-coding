# Optional Conda integration.
if [[ -x "$HOME/miniconda3/bin/conda" ]]; then
    __conda_setup="$($HOME/miniconda3/bin/conda shell.zsh hook 2>/dev/null)"
    if [[ $? -eq 0 ]]; then
        eval "$__conda_setup"
    elif [[ -r "$HOME/miniconda3/etc/profile.d/conda.sh" ]]; then
        . "$HOME/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="$HOME/miniconda3/bin:$PATH"
    fi
    unset __conda_setup
fi

# Optional Node Version Manager integration.
export NVM_DIR="$HOME/.nvm"
[[ -r "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh"
[[ -r "$NVM_DIR/bash_completion" ]] && . "$NVM_DIR/bash_completion"

# Oh My Zsh with the clean theme.
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="clean"
plugins=(git brew macos colored-man-pages)
[[ -r "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# Autosuggestions are optional until Homebrew is installed.
if command -v brew >/dev/null 2>&1; then
    _brew_prefix="$(brew --prefix)"
    _autosuggest_file="$_brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    [[ -r "$_autosuggest_file" ]] && source "$_autosuggest_file"
    unset _brew_prefix _autosuggest_file
fi

# JSON helpers.
alias jqp='jq -C .'
alias jqc='jq -C'

# Keep ripgrep configuration local to this shell function. Do not export
# RIPGREP_CONFIG_PATH globally, so other programs keep their own rg behavior.
unset RIPGREP_CONFIG_PATH
function rg() {
    RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config" command rg "$@"
}

# Optional OpenClaw completion.
[[ -r "$HOME/.openclaw/completions/openclaw.zsh" ]] && source "$HOME/.openclaw/completions/openclaw.zsh"

export CLICOLOR=1
export LSCOLORS=GxFxCxDxBxegedabagaced
alias ls='lsd'
alias l='lsd -l'
alias ll='lsd -l'
alias la='lsd -la'
alias lt='lsd --tree --depth=2'
export PATH="$HOME/.npm-global/bin:$PATH"

# Accept an autosuggestion with Tab; otherwise use normal zsh completion.
function _tab_complete_or_accept_suggestion() {
    if [[ -n "$POSTDISPLAY" ]]; then
        zle autosuggest-accept
    else
        zle expand-or-complete
    fi
}
zle -N _tab_complete_or_accept_suggestion
bindkey '^I' _tab_complete_or_accept_suggestion
bindkey -M viins '^I' _tab_complete_or_accept_suggestion

# Yazi shell wrapper: return to the directory visited before quitting.
function y() {
    local tmp cwd
    tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    command yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    if [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

